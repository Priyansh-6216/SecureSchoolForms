{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "form-route": {
        "ClusterId": "form-cluster",
        "Match": {
          "Path": "api/form/{**catchall}"
        }
      },
      "workflow-route": {
        "ClusterId": "workflow-cluster",
        "Match": {
          "Path": "api/workflow/{**catchall}"
        }
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": {
          "Path": "api/audit/{**catchall}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "api/notification/{**catchall}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "api/auth/{**catchall}"
        }
      },
      "document-route": {
        "ClusterId": "document-cluster",
        "Match": {
          "Path": "api/document/{**catchall}"
        }
      }
    },
    "Clusters": {
      "form-cluster": {
        "Destinations": {
          "form-destination": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "workflow-cluster": {
        "Destinations": {
          "workflow-destination": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "audit-destination": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-destination": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://localhost:5005/"
          }
        }
      },
      "document-cluster": {
        "Destinations": {
          "document-destination": {
            "Address": "http://localhost:5006/"
          }
        }
      }
    }
  }
}

